# Docker compose uses `postgres` as the hostname.
# Local direct commands can temporarily override with:
# postgresql://jobhunter:jobhunter@localhost:5432/jobhunter
POSTGRES_DB=jobhunter
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=jobhunter
DATABASE_URL=postgresql://jobhunter:jobhunter@postgres:5432/jobhunter
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-me
PLAYWRIGHT_HEADLESS=true
JOBHUNTER_FIT_THRESHOLD=70
JOBHUNTER_ENABLE_DEMO_SEED=false
JOBHUNTER_AUTO_APPLY_ENABLED=false
JOBHUNTER_AUTO_APPLY_DRY_RUN=true
JOBHUNTER_EXTERNAL_AUTOFILL_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_URL=
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
JOBHUNTER_GREENHOUSE_BOARDS=stripe,figma
JOBHUNTER_ASHBY_BOARDS=vercel,retool
JOBHUNTER_LEVER_SITES=box
JOBHUNTER_WORKABLE_COMPANIES=
