{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "apps/web/src/*"
      ],
      "@jobhunter/core": [
        "packages/core/src/index.ts"
      ],
      "@jobhunter/db": [
        "packages/db/src/index.ts"
      ],
      "@jobhunter/automation": [
        "packages/automation/src/index.ts"
      ],
      "@jobhunter/job-sources": [
        "packages/job-sources/src/index.ts"
      ],
      "@jobhunter/llm": [
        "packages/llm/src/index.ts"
      ]
    }
  }
}
